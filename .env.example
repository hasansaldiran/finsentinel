# FinSentinel — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyala: cp .env.example .env
# .env dosyasını ASLA git'e pushlamayın!

# === AI API Seçenekleri (birini veya birkaçını kullanın) ===

# Google Gemini (ücretsiz 15 RPM / 1500 RPD)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (ÇOK hızlı, ücretsiz tier) — ÖNERİLEN
# https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic (artık kullanılmıyor)
ANTHROPIC_API_KEY=sk-ant-...

# === TCMB EVDS API ===
# https://evds2.tcmb.gov.tr/ adresinden ücretsiz alınır
TCMB_API_KEY=

# === Telegram Bot (Bildirimler) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Virgülle ayrılmış ek izinli chat ID'leri (güvenlik whitelist)
# Örnek: TELEGRAM_ALLOWED_CHATS=123456789,987654321
TELEGRAM_ALLOWED_CHATS=

# === Alpha Vantage (Dünya borsaları, forex - ücretsiz tier mevcut) ===
ALPHA_VANTAGE_API_KEY=

# === CoinGecko (Kripto - ücretsiz tier yeterli) ===
COINGECKO_API_KEY=

# === Kullanıcı Şifreleri (.env'e yaz, kaynak koda YAZMA) ===
USER_HSALDIRAN_PASS=
USER_ADMIN_PASS=

# === Finnhub (BIST quasi-realtime, ücretsiz tier) ===
# https://finnhub.io/register
FINNHUB_API_KEY=

# === TradingView (artık kullanılmıyor — kaldırıldı) ===
# TV_USERNAME=
# TV_PASSWORD=

# === Uygulama Ayarları ===
APP_ENV=development
APP_PORT=8501
APP_HOST=0.0.0.0
APP_PASSWORD=finsentinel2024

# === Veritabanı ===
DB_PATH=data/finsentinel.db

# === Redis (Opsiyonel - yoksa SQLite cache kullanılır) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === Loglama ===
LOG_LEVEL=INFO
LOG_FILE=logs/finsentinel.log
