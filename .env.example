# FinSentinel — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# .env dosyası .gitignore ile korunur — asla commit etmeyin

# ── Google Gemini AI ──────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── TCMB EVDS API ────────────────────────────────────
TCMB_API_KEY=your_tcmb_evds_api_key_here

# ── Telegram Bot (alarmlar için) ─────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── CoinGecko API (Pro kullanıyorsanız) ──────────────
COINGECKO_API_KEY=

# ── Uygulama Ayarları ────────────────────────────────
APP_PASSWORD=
DEBUG=False
